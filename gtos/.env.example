# GTOS — Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus dados
# O setup/wizard.py faz isso automaticamente

# Operador
OPERADOR_NOME=Seu Nome

# Meta Ads API
META_ADS_ACCESS_TOKEN=seu_token_aqui
META_ADS_ACCOUNT_ID=id_da_conta_sem_act_

# Evolution Go (WhatsApp)
EVO_URL=http://localhost:8080
EVO_INSTANCE=nome-da-instancia
EVO_API_KEY=sua_api_key

# Telegram (aprovação de relatórios)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI (Whisper para voz)
OPENAI_API_KEY=
