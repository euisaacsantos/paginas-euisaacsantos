# =====================================================================
# Claude para Gestores de Tráfego — Variáveis de ambiente
# Copia esse arquivo pra .env e preenche.
# .env NUNCA vai pro git (já está no .gitignore).
# =====================================================================

# ===== Obsidian =====
# Path absoluto do vault. Pode usar o que vem no template:
OBSIDIAN_VAULT_PATH=./obsidian-vault

# ===== Meta Marketing API =====
# Token de longa duração. Gera em https://developers.facebook.com/tools/explorer/
# Permissões necessárias: ads_read, ads_management, business_management
META_ACCESS_TOKEN=
# ID da conta de anúncios principal (formato act_123456789)
META_AD_ACCOUNT_ID=act_
# ID do Business Manager (opcional, mas recomendado pra multi-conta)
META_BUSINESS_ID=
# Versão da API a usar (deixa fixo pra evitar surpresa)
META_API_VERSION=v19.0

# ===== Evolution Go (WhatsApp self-hosted) =====
EVOLUTION_API_URL=http://localhost:8080
# Gera uma chave forte. Default no docker-compose é "change-me-strong-key"
EVOLUTION_API_KEY=change-me-strong-key
EVOLUTION_INSTANCE_NAME=gestor

# ===== Destinos de notificação =====
# Número que recebe alertas do gestor (com DDI, sem +, sem espaço)
WHATSAPP_DESTINO=5511999998888

# ===== Google Drive MCP =====
# Path absoluto do JSON de credenciais OAuth do Google Cloud
GDRIVE_CREDENTIALS_PATH=~/.gestor-trafego/gdrive-credentials.json
GDRIVE_TOKEN_PATH=~/.gestor-trafego/gdrive-token.json

# ===== Playwright (espionagem) =====
# Headless por padrão. Mude pra false só quando estiver debugando
PLAYWRIGHT_HEADLESS=true
# Cookie da Biblioteca Meta (opcional, só se a Biblioteca exigir login)
META_LIBRARY_COOKIE=

# ===== Operacional =====
# Path onde a skill master guarda estado (cron, snapshots, cache)
GESTOR_STATE_DIR=~/.gestor-trafego
# Locale pra formatação de número/data nos relatórios
LOCALE=pt-BR
TIMEZONE=America/Sao_Paulo
